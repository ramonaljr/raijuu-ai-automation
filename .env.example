# Database
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
DATABASE_URL_CI=postgresql://user:pass@host-ci/db?sslmode=require

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk routing (defaults are fine, override if needed)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/app
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/app

# Cal.com (public username for booking CTA)
NEXT_PUBLIC_CAL_USERNAME=

# Resend (admin notification email on each demo submission)
RESEND_API_KEY=
RESEND_FROM=
RESEND_ADMIN_EMAIL=

# Kill-switch: set to 1 to suppress all outbound Resend calls (recommended for e2e/CI)
DISABLE_OUTBOUND_EMAIL=

# Cloudflare Turnstile (bot check on demo form)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# IP hashing salt (change in prod for privacy)
IP_HASH_SALT=

# App base URL (ensures magic-link emails point at the right domain in prod)
APP_BASE_URL=http://localhost:3000

# n8n webhook (Phase 4)
# Shared secret with the n8n HTTP Request node. Bearer-token auth on /api/n8n/run-callback.
N8N_WEBHOOK_SECRET=

# Cron secret (Phase 4)
# Authorizes /api/cron/aggregate-monthly. Vercel Cron auto-injects this when the project env var is set.
CRON_SECRET=
