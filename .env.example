# Database
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk routing (defaults are fine, override if needed)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/app
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/app

# Cal.com (public username for booking CTA)
NEXT_PUBLIC_CAL_USERNAME=

# Resend (admin notification email on each demo submission)
RESEND_API_KEY=
RESEND_FROM=
RESEND_ADMIN_EMAIL=

# Kill-switch: set to 1 to suppress all outbound Resend calls (recommended for e2e/CI)
DISABLE_OUTBOUND_EMAIL=

# Cloudflare Turnstile (bot check on demo form)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# IP hashing salt (change in prod for privacy)
IP_HASH_SALT=

# App base URL (ensures magic-link emails point at the right domain in prod)
APP_BASE_URL=http://localhost:3000

# Support email shown in portal/help/settings/no-engagement. Public (mailto: is
# rendered in HTML). Falls back to hello@raijuu.io if unset.
NEXT_PUBLIC_SUPPORT_EMAIL=

# n8n webhook (Phase 4)
# Shared secret with the n8n HTTP Request node. Bearer-token auth on /api/n8n/run-callback.
N8N_WEBHOOK_SECRET=

# Cron secret (Phase 4)
# Authorizes /api/cron/aggregate-monthly. Vercel Cron auto-injects this when the project env var is set.
CRON_SECRET=

# n8n deep-link base URL — admin automations table links to <base>/workflow/<id>
# when set. Falls back to plain text otherwise.
N8N_BASE_URL=

# Sentry (optional). Server + edge init no-op without SENTRY_DSN; client init
# no-ops without NEXT_PUBLIC_SENTRY_DSN. next.config wraps with Sentry only
# when SENTRY_DSN is set, so local builds without Sentry stay untouched.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Source-map upload on deploy: set all three to enable. Auth token scoped to
# "project:releases" + "project:read" is enough.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
